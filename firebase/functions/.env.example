# ============================================
# Firebase Cloud Functions 環境變數範例
# ============================================
#
# 使用方式：
# 1. 本地測試：複製此檔案為 .env 並填入實際值
# 2. 生產環境：使用 Google Cloud Secret Manager
#
# 注意：
# - .env 檔案僅用於本地測試
# - 生產環境的 OPENAI_API_KEY 使用 Secret Manager
# - 不要將 .env 檔案提交到版本控制
# ============================================

# ============================================
# OpenAI API 配置
# ============================================

# OpenAI API 金鑰（必填）
# 本地測試：在此填入金鑰
# 生產環境：使用 Secret Manager
#   設定指令：firebase functions:secrets:set OPENAI_API_KEY
#   取得金鑰：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Translation Settings
# 是否啟用自動翻譯（onCreate 觸發）
ENABLE_AUTO_TRANSLATE=true

# 目標翻譯語言清單（已棄用）
# 新版本會自動根據聊天室中用戶的語言偏好進行翻譯
# - 只翻譯接收者的語言（從 users/{userId}.preferredLang 讀取）
# - 額外翻譯成英文作為後備（如果雙方都不是英文）
# 這樣可以大幅降低翻譯成本
# TARGET_LANGUAGES=zh-TW,en,ja,ko,vi,th,ms,id

# OpenAI Model Configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.3

# Cost Control Settings
# 長訊息截斷閾值（字元數）
MAX_AUTO_TRANSLATE_LENGTH=500

# 快取時間（秒）
TRANSLATION_CACHE_TTL=600

# 併發控制
MAX_CONCURRENT_TRANSLATIONS=2

# Retry Configuration
MAX_RETRY_ATTEMPTS=2
RETRY_DELAY_MS=1000

# Firebase Project Configuration
# 這些通常由 Firebase Functions 自動提供，無需手動設定
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

