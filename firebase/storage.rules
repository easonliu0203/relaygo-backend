rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 用戶頭像上傳
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024 && // 5MB 限制
        request.resource.contentType.matches('image/.*');
    }
    
    // 司機證件上傳
    match /driver_documents/{driverId}/{allPaths=**} {
      allow read: if request.auth != null && 
        (request.auth.uid == driverId || request.auth.token.admin == true);
      allow write: if request.auth != null && 
        request.auth.uid == driverId &&
        request.resource.size < 10 * 1024 * 1024 && // 10MB 限制
        request.resource.contentType.matches('image/.*|application/pdf');
    }
    
    // 車輛照片上傳
    match /vehicle_photos/{driverId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        request.auth.uid == driverId &&
        request.resource.size < 5 * 1024 * 1024 && // 5MB 限制
        request.resource.contentType.matches('image/.*');
    }
    
    // 訂單相關檔案 (收據、發票等)
    match /booking_files/{bookingId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.resource.size < 5 * 1024 * 1024 && // 5MB 限制
        request.resource.contentType.matches('image/.*|application/pdf');
    }
    
    // 公司相關檔案 (僅限管理員)
    match /company_files/{companyId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        request.auth.token.admin == true &&
        request.resource.size < 20 * 1024 * 1024; // 20MB 限制
    }
  }
}
