{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "noEmit": false,
    "noEmitOnError": false,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true
  },
  "include": [
    "src/minimal-server.ts",
    "src/routes/bookingFlow-minimal.ts",
    "src/config/**/*.ts",
    "src/utils/**/*.ts",
    "src/types/**/*.ts"
  ],
  "exclude": [
    "src/controllers/**",
    "src/middleware/**",
    "src/services/**",
    "src/routes/**",
    "src/**/__tests__/**",
    "**/*.spec.ts"
  ]
}
