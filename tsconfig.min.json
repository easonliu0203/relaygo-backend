{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "noEmit": false,
    "noEmitOnError": false,

    // 放寬型別與檢查，避免攔住 minimal build
    "exactOptionalPropertyTypes": false,
    "useUnknownInCatchVariables": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    // 加速與降噪
    "skipLibCheck": true
  },
  "include": [
    "src/minimal-server.ts",
    "src/config/**/*.ts",
    "src/utils/**/*.ts",
    "src/types/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "**/*.spec.ts",
    // 明確排除整包 services 與 routes（避免被 import 鏈接牽出來）
    "src/services/**",
    "src/routes/**",
    "src/middleware/**",
    "src/controllers/**"
  ]
}
