# 伺服器配置
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
WEB_ADMIN_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# Firebase Admin SDK 配置
# 請從 Firebase Console > 專案設定 > 服務帳戶 下載私鑰檔案
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# Supabase 配置
# 請從 Supabase Dashboard > Settings > API 獲取
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 資料庫配置 (如果使用直接連接)
DATABASE_URL=postgresql://username:password@localhost:5432/ride_booking

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 支付系統設定 (分階段配置)
# 階段一：封測版本 (使用模擬支付)
PAYMENT_PROVIDER=mock
PAYMENT_TEST_MODE=true

# 模擬支付設定
MOCK_PAYMENT_SUCCESS_RATE=0.9
MOCK_PAYMENT_DELAY=2000
MOCK_PAYMENT_ENABLE_FAILURE=true

# 線下支付設定
OFFLINE_PAYMENT_EXPIRY_HOURS=24
OFFLINE_AUTO_REMINDER=true
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# GoMyPay 支付設定
GOMYPAY_MERCHANT_ID=your-gomypay-merchant-id
GOMYPAY_API_KEY=your-gomypay-api-key
GOMYPAY_TEST_MODE=true
GOMYPAY_RETURN_URL=http://localhost:3000/api/payment/gomypay/return
GOMYPAY_CALLBACK_URL=http://localhost:3000/api/payment/gomypay/callback

# 階段二：正式版本 (真實金流)
# 信用卡支付 (綠界為例)
CREDIT_CARD_MERCHANT_ID=your-merchant-id
CREDIT_CARD_API_KEY=your-api-key
CREDIT_CARD_API_SECRET=your-api-secret
CREDIT_CARD_WEBHOOK_SECRET=your-webhook-secret
CREDIT_CARD_RETURN_URL=http://localhost:3000/api/payment/return
CREDIT_CARD_NOTIFY_URL=http://localhost:3000/api/payment/notify

# Stripe 支付配置
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id

# 電子錢包支付
DIGITAL_WALLET_APP_ID=your-app-id
DIGITAL_WALLET_APP_SECRET=your-app-secret
DIGITAL_WALLET_MERCHANT_ID=your-merchant-id
DIGITAL_WALLET_NOTIFY_URL=http://localhost:3000/api/payment/wallet/notify

# 銀行轉帳設定
BANK_TRANSFER_BANK_CODE=your-bank-code
BANK_TRANSFER_ACCOUNT_NUMBER=your-account-number
BANK_TRANSFER_ACCOUNT_NAME=your-account-name
BANK_TRANSFER_AUTO_VERIFY=false

# 第三方服務配置
# Twilio (SMS 驗證)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# 簡訊服務 (以三竹為例)
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret

# OpenAI (聊天翻譯)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# 郵件服務 (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# 檔案上傳配置
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# 日誌配置
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# 監控配置
SENTRY_DSN=your-sentry-dsn
ENABLE_METRICS=true

# 快取配置
CACHE_TTL=3600  # 1 hour
CACHE_MAX_ITEMS=1000

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# 推播通知配置
FCM_SERVER_KEY=your-fcm-server-key

# 推薦碼設定
REFERRAL_CODE_LENGTH=8
REFERRAL_CODE_EXPIRY_DAYS=365

# 定位更新頻率 (秒)
LOCATION_UPDATE_INTERVAL=60

# 聊天室設定
CHAT_HISTORY_RETENTION_DAYS=60
CHAT_OPEN_HOURS_BEFORE=24
CHAT_OPEN_HOURS_AFTER=24

# 價格設定 (可由後台覆蓋)
DEFAULT_PLATFORM_COMMISSION=0.25  # 25%
DEFAULT_DEPOSIT_PERCENTAGE=0.25   # 25%
FOREIGN_LANGUAGE_SURCHARGE=2000   # NT$2000/day

# 取消政策 (小時)
FULL_REFUND_HOURS=168    # 7天前
HALF_REFUND_HOURS=24     # 1天前

# 司機保證金
DRIVER_DEPOSIT_AMOUNT=10000
LATE_CANCELLATION_PENALTY=2000
NO_SHOW_PENALTY=1000

# 開發工具配置
ENABLE_SWAGGER=true
ENABLE_CORS=true
ENABLE_MORGAN_LOGGING=true

